# --- Frontend (Vite) ---
# Leave EMPTY for production (nginx proxies /api/ to the backend).
# Only needed in dev if NOT using Vite's built-in proxy.
VITE_API_URL=
VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# --- Backend (Hono) ---
# Generate a new secret: openssl rand -hex 32
JWT_SECRET=e3574766c5f7b6cf94fe533b69cbc979c7d19596ec78d09b22f436b8ab89ada4
PORT=3001
# Comma-separated origins allowed by CORS.
# Dev: http://localhost:5173
# Prod: https://neli.tr,https://www.neli.tr
CORS_ORIGIN=http://localhost:5173

# --- Odoo CRM (optional) ---
# Barındırılan Odoo (HTTPS): tam adresi kullanın — ODOO_URL varken HOST/PORT isteğe bağlıdır.
# ODOO_URL=https://yourcompany.odoo.com
ODOO_HOST=localhost
ODOO_PORT=8069
# Yerel HTTP dışında HTTPS kullanıyorsanız: ODOO_USE_SSL=true (veya ODOO_HOST=https://sunucu)
ODOO_USE_SSL=false
ODOO_DB=your_odoo_db
ODOO_USERNAME=your_odoo_user
ODOO_PASSWORD=your_odoo_password
# Takvim randevularını başka bir kullanıcının takvimine yazmak için (yoksa ODOO_USERNAME uid kullanılır)
# ODOO_APPOINTMENT_USER_ID=2

# --- Web randevu (calendar.event) — APPOINTMENT_* frontend src/lib/appointment-slots.ts ile uyumlu tutun ---
APPOINTMENT_DURATION_HOURS=2
APPOINTMENT_WEEKDAY_START=9
APPOINTMENT_WEEKDAY_END=18
APPOINTMENT_SATURDAY_START=10
APPOINTMENT_SATURDAY_END=14
